{
    "$schema": "https://opencode.ai/config.json",
    "username": "sandikodev",
    "default_agent": "build",
    "instructions": [
        ".opencode/SHARED/project-context.md",
        ".opencode/SHARED/agent-rules.md"
    ],
    "references": {
        "docs": {
            "path": "../../smauii-aksesekolah/docs",
            "description": "Technical documentation for SMART Absen — architecture, ERD, deployment"
        },
        "monorepo": {
            "path": "../../smauii-aksesekolah",
            "description": "Monorepo entrypoint — brief, docs, .opencode, .openkb"
        },
        "playbook": {
            "path": "../../smauii-playbook",
            "description": "SOP, workflow, template, ADR, role definitions, AI workflows"
        },
        "kaede": {
            "path": "../../kaede-powerup",
            "description": "KAEDE — Two global MCP servers: mcp.kaede (4 context/plan tools) + mcp.trello (24 execute tools). Install: cd kaede-powerup && node scripts/kaede.mjs install"
        }
    },
    "agent": {
        "build": {
            "description": "Primary agent — Laravel coding, debugging, testing",
            "mode": "primary",
            "permission": {
                "edit": "allow",
                "bash": "ask"
            }
        },
        "plan": {
            "description": "Planning agent — analysis before coding",
            "mode": "primary",
            "permission": {
                "edit": "deny"
            }
        }
    },
    "command": {
        "test": {
            "description": "Run PHPUnit tests",
            "template": "php artisan test $ARGUMENTS"
        },
        "lint": {
            "description": "Check coding style with Laravel Pint",
            "template": "./vendor/bin/pint --test"
        },
        "fix": {
            "description": "Fix coding style automatically",
            "template": "./vendor/bin/pint"
        },
        "dev": {
            "description": "Start Vite dev server (hot reload)",
            "template": "bun run dev"
        },
        "build": {
            "description": "Build frontend assets",
            "template": "bun run build"
        },
        "migrate": {
            "description": "Run database migrations",
            "template": "php artisan migrate $ARGUMENTS"
        },
        "fresh": {
            "description": "Migrate fresh + seed",
            "template": "php artisan migrate:fresh --seed"
        },
        "kaede-today": {
            "description": "Show today's Trello tasks",
            "template": "kaede today"
        },
        "kaede-status": {
            "description": "Check KAEDE & Trello connection status",
            "template": "kaede status --mcp"
        },
        "kaede-generate-plan": {
            "description": "Generate action plan from intent (quick alternative to mcp.kaede.generate_plan)",
            "template": "node scripts/kaede.mjs run --dry-run --playbook '../smauii-playbook' $ARGUMENTS"
        }
    }
}
